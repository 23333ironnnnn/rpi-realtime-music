# Copy to .env on the Pi (do not commit .env).
# Upload web (Flask)
UPLOAD_WEB_PASSWORD=change-me
BASIC_USER=pi
PORT=8080
INBOX_DIR=/opt/rpi_realtime_music/inbox_mp3
MAX_UPLOAD_BYTES=52428800

# After each successful upload, run the one-shot pipeline (same as ~/run_pipeline.sh).
# Requires MINIMAX_API_KEY (and any other vars) to be present in this .env — the child
# process inherits the upload service environment.
RUN_PIPELINE_ON_UPLOAD=0
RUN_PIPELINE_SCRIPT=/home/pi/run_pipeline.sh
RUN_PIPELINE_SPAWN_LOG=/opt/rpi_realtime_music/logs/pipeline_spawn.log
# MINIMAX_API_KEY=your-key-here
